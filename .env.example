# ---- Server ----
PORT=8080
PUBLIC_WSS_URL=wss://your-deployed-host/ws/voice   # TLS WebSocket the TwiML points to
AGENT_NAME=Max                                      # sales persona name (see docs/sales-agent-playbook.md)

# ---- Twilio ----
# SID is an identifier (not secret). The Auth Token is password-equivalent — prefer a
# scoped Standard API Key (SID+Secret) over the account Auth Token. NEVER commit real values.
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=__set_in_host_secrets__

# ---- ConversationRelay voice (Twilio does ASR+TTS) ----
ELEVENLABS_VOICE_ID=yuS5yvxd9cdXv5KzBa74            # "Max" sales voice (Jenny's is RRIjxt3K1iKEkfsLGRXU)
ASR_PROVIDER=deepgram
ASR_SPEECH_MODEL=nova-2-phonecall
TTS_PROVIDER=ElevenLabs
AGENT_LANGUAGE=en-US

# ---- Anthropic (the brain) ----
ANTHROPIC_API_KEY=__set_in_host_secrets__
ANTHROPIC_MODEL=claude-sonnet-4-6

# ---- Leads DB (Supabase: dedicated 'Sales Call Agent' project, `sales` schema) ----
LEADS_SUPABASE_URL=https://ztgerulyxaltuhsodrne.supabase.co
LEADS_SUPABASE_SERVICE_KEY=__set_in_host_secrets__  # service-role key; bypasses RLS

# ---- Inventory DB (Supabase: Inventory Management project, read-only) ----
INVENTORY_SUPABASE_URL=https://qunnxsxeevoeflqfrzwz.supabase.co
INVENTORY_SUPABASE_KEY=__set_in_host_secrets__      # read-only key is sufficient

# ---- Behaviour ----
RECORD_CALLS=false                                  # if true, plays consent notice + <Start><Recording>
FORCE_AGENT_ACTIVE=false                             # set true to make the agent answer at ANY hour (testing only)
MAKE_NOTIFY_WEBHOOK=                                # optional: Make webhook for sales-team notifications
